# Canonical Neon project: fancy-surf-46017809
# Keep DATABASE_URL and NEON_AUTH_BASE_URL from the same Neon branch.
# For local development, copy these values into .env.local.

DATABASE_URL=
# Owner/admin connection string used by automatic deploy/runtime schema initialization when DATABASE_URL uses a restricted app role.
DATABASE_OWNER_URL=
# Optional: runtime DB role to grant app-table privileges to. If omitted, initialization can infer it from DATABASE_URL when DATABASE_OWNER_URL is set.
APP_DATABASE_ROLE=
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=
# AI generation uses Vertex AI through the official @google/genai SDK.
# Local development should use Application Default Credentials:
#   gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
# Backward-compatible aliases if a hosting provider already uses these names.
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=
# Optional only when service-account keys are allowed. Prefer ADC / workload identity when possible.
VERTEX_AI_SERVICE_ACCOUNT_JSON=
VERTEX_AI_SERVICE_ACCOUNT_JSON_BASE64=
# Production on Vercel without JSON keys: OIDC -> Google Workload Identity Federation.
GCP_PROJECT_ID=
GCP_PROJECT_NUMBER=
GCP_SERVICE_ACCOUNT_EMAIL=
GCP_WORKLOAD_IDENTITY_POOL_ID=
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=
# Required when object/file storage is enabled. Celion uses Cloudflare R2, not Vercel Blob.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=
